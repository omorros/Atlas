# Copy to api/.env and fill in secrets (never commit .env).

ANTHROPIC_API_KEY=
ANTHROPIC_TRIAGE_MODEL=claude-3-5-haiku-20241022
ANTHROPIC_ANALYST_MODEL=claude-sonnet-4-20250514
OPENAI_API_KEY=
SPECTER_API_KEY=
SPECTER_BASE_URL=https://api.specter.com/v1
DATABASE_URL=sqlite+aiosqlite:///./data/radar.db
SIDECAR_URL=http://localhost:8001

# Spine (optional): protect /internal/investigation-events
# INTERNAL_TOKEN=

# Demo reset — set to 0 to disable POST /demo/reset in shared envs
DEMO_RESET_ENABLED=1

# Runway “calibrated” burn inputs (USD / days)
METRICS_POLICY_DAILY_BURN_USD=35000
METRICS_MIN_DAILY_BURN_USD=2000
METRICS_BURN_LOOKBACK_DAYS=30
