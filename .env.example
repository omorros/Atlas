# Copy to .env at the repo root and fill in. Each subproject also has its own .env.example.
# Without these keys the system runs in fallback mode (canned data, no real LLM calls).

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
SPECTER_API_KEY=
CURSOR_API_KEY=

NEXT_PUBLIC_MAPBOX_TOKEN=
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/events/stream
NEXT_PUBLIC_SIDECAR_URL=http://localhost:8001
